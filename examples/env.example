# Core service
NODE_ENV=development
PORT=8787
HOST=127.0.0.1
LOG_LEVEL=info

# Alexa custom skill
ALEXA_SKILL_ID=amzn1.ask.skill.REPLACE_WITH_SKILL_ID
ALEXA_USER_HASH_SALT=replace-with-random-local-secret-at-least-16-chars

# OpenClaw adapter
OPENCLAW_ASSISTANT_ID=assistant
OPENCLAW_ADAPTER=cli
OPENCLAW_CLI_BIN=openclaw
OPENCLAW_CLI_TIMEOUT_MS=2500
OPENCLAW_CLI_DRAIN_TIMEOUT_MS=120000
OPENCLAW_CLI_THINKING=minimal
OPENCLAW_SESSION_KEY=agent:assistant:main
OPENCLAW_INGEST_URL=
OPENCLAW_INGEST_TOKEN=
QUEUE_PATH=./data/queue.jsonl
QUEUE_DRAIN_INTERVAL_MS=30000
QUEUE_MAX_ATTEMPTS=3

# Internal API
BRIDGE_INTERNAL_TOKEN=replace-with-random-token-at-least-24-chars

# Home Assistant announcements
HA_URL=http://127.0.0.1:8123
HA_TOKEN=
HA_WEBHOOK_ID=replace-with-bridge-specific-local-webhook-id
HA_DEFAULT_TARGET=office
HA_ALLOWED_TARGETS=office=notify.office_announce,living_room=notify.living_room_announce,everywhere=notify.everywhere_announce
ANNOUNCEMENT_MAX_LENGTH=240
ANNOUNCEMENT_RATE_LIMIT_MS=30000

# Test/development only. Never set true in production.
ALLOW_UNSIGNED_ALEXA_REQUESTS=false
